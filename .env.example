# Copy this file to .env and fill in your own values.
# On Railway, set these as real environment variables in the service's
# "Variables" tab instead - do not commit a filled-in .env file.

OCI_REGION=
OCI_USER_ID=
OCI_TENANCY_ID=
OCI_KEY_FINGERPRINT=

# Absolute path to your OCI API private key (.pem), or a direct publicly
# accessible URL to it.
OCI_PRIVATE_KEY_FILENAME=

# Leave empty to try all availability domains in the region, or set a single
# one (e.g. jYtI:PHX-AD-1) or a JSON array of them.
OCI_AVAILABILITY_DOMAIN=

OCI_SUBNET_ID=
OCI_IMAGE_ID=

OCI_OCPUS=1
OCI_MEMORY_IN_GBS=6
OCI_SHAPE=VM.Standard.A1.Flex

# How many running instances of OCI_SHAPE are acceptable before the script
# stops trying to create more.
OCI_MAX_INSTANCES=1

# ssh-ed25519 / ssh-rsa public key, single line, no newlines.
OCI_SSH_PUBLIC_KEY=

OCI_BOOT_VOLUME_SIZE_IN_GBS=50
OCI_BOOT_VOLUME_ID=

CACHE_AVAILABILITY_DOMAINS=1

# Cooldown (seconds) to wait after OCI responds with 429 Too Many Requests.
TOO_MANY_REQUESTS_TIME_WAIT=600

# Continuous mode only (worker.php / Railway) - seconds between attempts
# when not rate-limited. Cron/GitHub Actions mode (index.php) ignores this.
POLL_INTERVAL_SECONDS=60

# Optional: get a Telegram message when an instance is successfully created.
# https://core.telegram.org/bots
TELEGRAM_BOT_API_KEY=
TELEGRAM_USER_ID=
